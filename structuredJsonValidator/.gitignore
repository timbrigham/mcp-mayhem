__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/
dist/
*.tmp
# Runtime server logs (e.g. server.out.log / server.err.log from a direct run).
*.log
# Real data + integrity sidecars. Everything the server writes under data/ is
# treated as private live data and kept out of git. The exceptions are the
# demo/fixture sample.json and the vocab sample, which are safe to track.
# The live, consumer-owned tag_vocab.json stays private (matched by data/*).
data/*
!data/sample.json
!data/tag_vocab.sample.json
